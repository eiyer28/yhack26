# Polymarket CLOB API credentials
# Copy this file to .env and fill in your values.
#
# Read-only endpoints (market discovery, pricing) are public and work without
# these credentials.  Setting them routes requests through your authenticated
# account, which gets higher rate limits.
#
# Obtain credentials at: https://polymarket.com  (Account -> API Keys)
# or via the py-clob-client:  client.create_or_derive_api_creds()

POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
